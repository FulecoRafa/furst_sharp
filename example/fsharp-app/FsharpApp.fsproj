<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <!-- Required for P/Invoke to locate the native .so on Linux -->
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <AssemblyName>FsharpApp</AssemblyName>
    <RootNamespace>FsharpApp</RootNamespace>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Generated bindings must be compiled before Program.fs -->
    <Compile Include="Generated/FurstBindings.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

</Project>
